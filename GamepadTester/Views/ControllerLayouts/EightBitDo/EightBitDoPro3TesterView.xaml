<UserControl x:Class="GamepadTester.Views.ControllerLayouts.EightBitDo.EightBitDoPro3TesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GamepadTester.Converters"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ControllerFill" Color="#11151B" />
        <SolidColorBrush x:Key="SurfaceFill" Color="#1D232E" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DCE4" />
        <SolidColorBrush x:Key="MutedLineBrush" Color="#6F7889" />
        <SolidColorBrush x:Key="InputIdleFill" Color="Transparent" />
        <SolidColorBrush x:Key="InputActiveFill" Color="#6631C48D" />
        <SolidColorBrush x:Key="InputActiveStroke" Color="#64F0B7" />
        <SolidColorBrush x:Key="TriggerTrack" Color="#0E1117" />

        <converters:BoolToBrushConverter x:Key="InputFillBrush"
                                         FalseBrush="{StaticResource InputIdleFill}"
                                         TrueBrush="{StaticResource InputActiveFill}" />
        <converters:BoolToBrushConverter x:Key="InputStrokeBrush"
                                         FalseBrush="{StaticResource LineBrush}"
                                         TrueBrush="{StaticResource InputActiveStroke}" />
        <converters:BoolToBrushConverter x:Key="ActiveOnlyStrokeBrush"
                                         FalseBrush="{StaticResource InputIdleFill}"
                                         TrueBrush="{StaticResource InputActiveStroke}" />

        <Style x:Key="MapLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#F4F6FA" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="760" Height="500">
            <Border Canvas.Left="116" Canvas.Top="12" Width="170" Height="46" CornerRadius="18,18,10,10"
                    Background="{StaticResource TriggerTrack}" BorderBrush="{StaticResource LineBrush}" BorderThickness="2" Padding="3">
                <Grid ClipToBounds="True">
                    <Rectangle HorizontalAlignment="Left" Width="{Binding LeftTriggerMapWidth}" RadiusX="12" RadiusY="12"
                               Fill="{StaticResource InputActiveStroke}" Opacity="0.86" />
                    <TextBlock Text="{Binding LeftTriggerPercent, StringFormat=LT / L2  {0}%}"
                               Foreground="#F4F6FA" FontWeight="SemiBold" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Canvas.Left="474" Canvas.Top="12" Width="170" Height="46" CornerRadius="18,18,10,10"
                    Background="{StaticResource TriggerTrack}" BorderBrush="{StaticResource LineBrush}" BorderThickness="2" Padding="3">
                <Grid ClipToBounds="True">
                    <Rectangle HorizontalAlignment="Left" Width="{Binding RightTriggerMapWidth}" RadiusX="12" RadiusY="12"
                               Fill="{StaticResource InputActiveStroke}" Opacity="0.86" />
                    <TextBlock Text="{Binding RightTriggerPercent, StringFormat=RT / R2  {0}%}"
                               Foreground="#F4F6FA" FontWeight="SemiBold" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Path x:Name="LeftBumper"
                  Data="M142,86 C174,68 250,68 286,88 L276,116 C232,102 184,102 150,116 Z"
                  Fill="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputStrokeBrush}}"
                  StrokeThickness="3" StrokeLineJoin="Round" />

            <Path x:Name="RightBumper"
                  Data="M474,88 C510,68 586,68 618,86 L610,116 C576,102 528,102 484,116 Z"
                  Fill="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputStrokeBrush}}"
                  StrokeThickness="3" StrokeLineJoin="Round" />

            <Path x:Name="ControllerBody"
                  Data="M190,116 C232,94 528,94 570,116 C642,154 662,274 638,366 C626,414 586,440 540,422 C504,408 486,356 446,340 C414,328 346,328 314,340 C274,356 256,408 220,422 C174,440 134,414 122,366 C98,274 118,154 190,116 Z"
                  Fill="{StaticResource ControllerFill}"
                  Stroke="{StaticResource LineBrush}"
                  StrokeThickness="4"
                  StrokeLineJoin="Round" />

            <Path x:Name="DpadBase"
                  Data="M210,202 L244,202 C248,202 250,204 250,208 L250,244 L286,244 C290,244 292,246 292,250 L292,284 C292,288 290,290 286,290 L250,290 L250,326 C250,330 248,332 244,332 L210,332 C206,332 204,330 204,326 L204,290 L168,290 C164,290 162,288 162,284 L162,250 C162,246 164,244 168,244 L204,244 L204,208 C204,204 206,202 210,202 Z"
                  Fill="{StaticResource SurfaceFill}"
                  Stroke="{StaticResource LineBrush}"
                  StrokeThickness="2.5"
                  StrokeLineJoin="Round" />
            <Path Data="M212,207 L242,207 L242,251 L212,251 Z"
                  Fill="{Binding State.Buttons.DpadUp, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.DpadUp, Converter={StaticResource ActiveOnlyStrokeBrush}}"
                  StrokeThickness="2" />
            <Path Data="M168,250 L212,250 L212,282 L168,282 Z"
                  Fill="{Binding State.Buttons.DpadLeft, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.DpadLeft, Converter={StaticResource ActiveOnlyStrokeBrush}}"
                  StrokeThickness="2" />
            <Path Data="M242,250 L286,250 L286,282 L242,282 Z"
                  Fill="{Binding State.Buttons.DpadRight, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.DpadRight, Converter={StaticResource ActiveOnlyStrokeBrush}}"
                  StrokeThickness="2" />
            <Path Data="M212,282 L242,282 L242,326 L212,326 Z"
                  Fill="{Binding State.Buttons.DpadDown, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.DpadDown, Converter={StaticResource ActiveOnlyStrokeBrush}}"
                  StrokeThickness="2" />
            <Rectangle Canvas.Left="212" Canvas.Top="250" Width="30" Height="32"
                       Fill="{StaticResource SurfaceFill}" Stroke="{StaticResource MutedLineBrush}" StrokeThickness="1" />

            <Ellipse Canvas.Left="292" Canvas.Top="256" Width="84" Height="84"
                     Fill="{Binding State.Buttons.LeftStick, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.LeftStick, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse Canvas.Left="309" Canvas.Top="273" Width="50" Height="50"
                     Fill="{StaticResource SurfaceFill}"
                     Stroke="{Binding State.Buttons.LeftStick, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />

            <Ellipse Canvas.Left="448" Canvas.Top="256" Width="84" Height="84"
                     Fill="{Binding State.Buttons.RightStick, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.RightStick, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse Canvas.Left="465" Canvas.Top="273" Width="50" Height="50"
                     Fill="{StaticResource SurfaceFill}"
                     Stroke="{Binding State.Buttons.RightStick, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />

            <Ellipse Canvas.Left="330" Canvas.Top="176" Width="30" Height="30"
                     Fill="{Binding State.Buttons.Back, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.Back, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="365" Canvas.Top="162" Width="30" Height="30"
                     Fill="{Binding State.Buttons.Guide, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.Guide, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="400" Canvas.Top="176" Width="30" Height="30"
                     Fill="{Binding State.Buttons.Start, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.Start, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />

            <Ellipse x:Name="ButtonNorth" Canvas.Left="544" Canvas.Top="172" Width="48" Height="48"
                     Fill="{Binding State.Buttons.North, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.North, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse x:Name="ButtonEast" Canvas.Left="594" Canvas.Top="222" Width="48" Height="48"
                     Fill="{Binding State.Buttons.East, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.East, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse x:Name="ButtonWest" Canvas.Left="494" Canvas.Top="222" Width="48" Height="48"
                     Fill="{Binding State.Buttons.West, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.West, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse x:Name="ButtonSouth" Canvas.Left="544" Canvas.Top="272" Width="48" Height="48"
                     Fill="{Binding State.Buttons.South, Converter={StaticResource InputFillBrush}}"
                     Stroke="{Binding State.Buttons.South, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />

            <Label Canvas.Left="544" Canvas.Top="172" Width="48" Height="48" Content="{Binding NorthLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="594" Canvas.Top="222" Width="48" Height="48" Content="{Binding EastLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="494" Canvas.Top="222" Width="48" Height="48" Content="{Binding WestLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="544" Canvas.Top="272" Width="48" Height="48" Content="{Binding SouthLabel}" Style="{StaticResource MapLabel}" />

            <TextBlock Canvas.Left="314" Canvas.Top="382" Width="132"
                       Text="8BitDo Pro 3"
                       Foreground="{StaticResource LineBrush}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       TextAlignment="Center" />
        </Canvas>
    </Viewbox>
</UserControl>
