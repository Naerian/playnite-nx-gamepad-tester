        <converters:BoolToBrushConverter x:Key="InputFillBrush"
                                         FalseBrush="{StaticResource InputIdleFill}"
                                         TrueBrush="{StaticResource InputActiveFill}" />
        <converters:BoolToBrushConverter x:Key="InputStrokeBrush"
                                         FalseBrush="{StaticResource LineBrush}"
                                         TrueBrush="{StaticResource InputActiveStroke}" />
        <converters:BoolToBrushConverter x:Key="ActiveOnlyStrokeBrush"
                                         FalseBrush="{StaticResource InputIdleFill}"
                                         TrueBrush="{StaticResource InputActiveStroke}" />

