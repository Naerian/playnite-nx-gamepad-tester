<UserControl x:Class="GamepadTester.Views.ControllerLayouts.XboxControllerTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GamepadTester.Converters"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ControllerFill" Color="#11151B" />
        <SolidColorBrush x:Key="SurfaceFill" Color="#1D232E" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DCE4" />
        <SolidColorBrush x:Key="MutedLineBrush" Color="#6F7889" />
        <SolidColorBrush x:Key="InputIdleFill" Color="Transparent" />
        <SolidColorBrush x:Key="InputActiveFill" Color="#6631C48D" />
        <SolidColorBrush x:Key="InputActiveStroke" Color="#64F0B7" />
        <SolidColorBrush x:Key="TriggerTrack" Color="#151922" />
        <SolidColorBrush x:Key="StickDotLeft" Color="#4CC9F0" />
        <SolidColorBrush x:Key="StickDotRight" Color="#F7B955" />
        <converters:BoolToBrushConverter x:Key="InputFillBrush" FalseBrush="{StaticResource InputIdleFill}" TrueBrush="{StaticResource InputActiveFill}" />
        <converters:BoolToBrushConverter x:Key="InputStrokeBrush" FalseBrush="{StaticResource LineBrush}" TrueBrush="{StaticResource InputActiveStroke}" />
        <converters:BoolToBrushConverter x:Key="ActiveOnlyStrokeBrush" FalseBrush="{StaticResource InputIdleFill}" TrueBrush="{StaticResource InputActiveStroke}" />
        <Style x:Key="MapLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#F4F6FA" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="760" Height="500">
            <TextBlock Canvas.Left="112" Canvas.Top="18" Width="174" Text="{Binding LeftTriggerPercent, StringFormat=LT  {0}%}" Foreground="#F4F6FA" FontWeight="SemiBold" TextAlignment="Center" />
            <Border Canvas.Left="138" Canvas.Top="50" Width="122" Height="6" CornerRadius="3" Background="{StaticResource TriggerTrack}" BorderBrush="{StaticResource MutedLineBrush}" BorderThickness="0.5" ClipToBounds="True">
                <Rectangle HorizontalAlignment="Left" Width="{Binding LeftTriggerThinMapWidth}" RadiusX="3" RadiusY="3" Fill="{StaticResource InputActiveStroke}" Opacity="0.86" />
            </Border>
            <TextBlock Canvas.Left="474" Canvas.Top="18" Width="174" Text="{Binding RightTriggerPercent, StringFormat=RT  {0}%}" Foreground="#F4F6FA" FontWeight="SemiBold" TextAlignment="Center" />
            <Border Canvas.Left="500" Canvas.Top="50" Width="122" Height="6" CornerRadius="3" Background="{StaticResource TriggerTrack}" BorderBrush="{StaticResource MutedLineBrush}" BorderThickness="0.5" ClipToBounds="True">
                <Rectangle HorizontalAlignment="Left" Width="{Binding RightTriggerThinMapWidth}" RadiusX="3" RadiusY="3" Fill="{StaticResource InputActiveStroke}" Opacity="0.86" />
            </Border>

            <Path Data="M132,88 C178,62 244,64 292,92 L278,126 C230,112 182,112 142,126 Z" Fill="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" StrokeLineJoin="Round" />
            <Path Data="M468,92 C516,64 582,62 628,88 L618,126 C578,112 530,112 482,126 Z" Fill="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" StrokeLineJoin="Round" />

            <Path Data="M174,116 C224,84 536,84 586,116 C650,158 672,270 644,366 C630,416 588,440 542,420 C502,402 488,350 446,334 C412,320 348,320 314,334 C272,350 258,402 218,420 C172,440 130,416 116,366 C88,270 110,158 174,116 Z"
                  Fill="{StaticResource ControllerFill}" Stroke="{StaticResource LineBrush}" StrokeThickness="4" StrokeLineJoin="Round" />

            <Ellipse Canvas.Left="192" Canvas.Top="182" Width="84" Height="84" Fill="{StaticResource SurfaceFill}" Stroke="{StaticResource MutedLineBrush}" StrokeThickness="2" />
            <Ellipse Canvas.Left="214" Canvas.Top="204" Width="40" Height="40" Fill="{StaticResource StickDotLeft}">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="{Binding LeftStickDotX}" Y="{Binding LeftStickDotY}" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Canvas.Left="414" Canvas.Top="282" Width="84" Height="84" Fill="{StaticResource SurfaceFill}" Stroke="{StaticResource MutedLineBrush}" StrokeThickness="2" />
            <Ellipse Canvas.Left="436" Canvas.Top="304" Width="40" Height="40" Fill="{StaticResource StickDotRight}">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="{Binding RightStickDotX}" Y="{Binding RightStickDotY}" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <Path Data="M245,278 L277,278 L277,310 L309,310 L309,342 L277,342 L277,374 L245,374 L245,342 L213,342 L213,310 L245,310 Z" Fill="{StaticResource SurfaceFill}" Stroke="{StaticResource LineBrush}" StrokeThickness="2.4" StrokeLineJoin="Round" />
            <Path Data="M249,282 L273,282 L273,314 L249,314 Z" Fill="{Binding State.Buttons.DpadUp, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadUp, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="2" />
            <Path Data="M217,314 L249,314 L249,338 L217,338 Z" Fill="{Binding State.Buttons.DpadLeft, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadLeft, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="2" />
            <Path Data="M273,314 L305,314 L305,338 L273,338 Z" Fill="{Binding State.Buttons.DpadRight, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadRight, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="2" />
            <Path Data="M249,338 L273,338 L273,370 L249,370 Z" Fill="{Binding State.Buttons.DpadDown, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadDown, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="2" />

            <Ellipse Canvas.Left="338" Canvas.Top="190" Width="28" Height="28" Fill="{Binding State.Buttons.Back, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.Back, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="366" Canvas.Top="166" Width="32" Height="32" Fill="{Binding State.Buttons.Guide, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.Guide, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="398" Canvas.Top="190" Width="28" Height="28" Fill="{Binding State.Buttons.Start, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.Start, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />

            <Ellipse Canvas.Left="538" Canvas.Top="168" Width="48" Height="48" Fill="{Binding State.Buttons.North, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.North, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse Canvas.Left="590" Canvas.Top="220" Width="48" Height="48" Fill="{Binding State.Buttons.East, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.East, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse Canvas.Left="486" Canvas.Top="220" Width="48" Height="48" Fill="{Binding State.Buttons.West, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.West, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Ellipse Canvas.Left="538" Canvas.Top="272" Width="48" Height="48" Fill="{Binding State.Buttons.South, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.South, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="3" />
            <Label Canvas.Left="538" Canvas.Top="168" Width="48" Height="48" Content="{Binding NorthLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="590" Canvas.Top="220" Width="48" Height="48" Content="{Binding EastLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="486" Canvas.Top="220" Width="48" Height="48" Content="{Binding WestLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="538" Canvas.Top="272" Width="48" Height="48" Content="{Binding SouthLabel}" Style="{StaticResource MapLabel}" />
        </Canvas>
    </Viewbox>
</UserControl>
