<UserControl x:Class="GamepadTester.Views.ControllerLayouts.XboxControllerTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GamepadTester.Converters"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ControllerFill" Color="#11151B" />
        <SolidColorBrush x:Key="SurfaceFill" Color="#1D232E" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DCE4" />
        <SolidColorBrush x:Key="MutedLineBrush" Color="#6F7889" />
        <SolidColorBrush x:Key="InputIdleFill" Color="Transparent" />
        <SolidColorBrush x:Key="InputActiveFill" Color="#6631C48D" />
        <SolidColorBrush x:Key="InputActiveStroke" Color="#64F0B7" />
        <SolidColorBrush x:Key="StickDotLeft" Color="#4CC9F0" />
        <SolidColorBrush x:Key="StickDotRight" Color="#F7B955" />

        <converters:BoolToBrushConverter x:Key="InputFillBrush" FalseBrush="{StaticResource InputIdleFill}" TrueBrush="{StaticResource InputActiveFill}" />
        <converters:BoolToBrushConverter x:Key="TriggerFillBrush" FalseBrush="{StaticResource SurfaceFill}" TrueBrush="{StaticResource InputActiveFill}" />
        <converters:BoolToBrushConverter x:Key="InputStrokeBrush" FalseBrush="{StaticResource LineBrush}" TrueBrush="{StaticResource InputActiveStroke}" />
        <converters:BoolToBrushConverter x:Key="ActiveOnlyStrokeBrush" FalseBrush="{StaticResource InputIdleFill}" TrueBrush="{StaticResource InputActiveStroke}" />

        <Style x:Key="MapLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#F4F6FA" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="500" Height="300">
            <Viewbox Canvas.Left="140" Canvas.Top="12" Width="72" Height="48" Stretch="Uniform">
                <Path Data="M58.689 67.9165L5.20399 73.9448C0.805227 74.4406 0.705254 71.4721 1.20511 69.9259C3.20455 62.3904 8.20315 44.4057 12.202 32.7509C17.2006 18.1822 32.6963 9.13966 38.6946 6.62782C44.6929 4.116 57.6893 2.10654 72.6851 1.1018C84.6817 0.298019 89.6803 4.4509 90.6801 6.62782C96.1785 19.187 107.975 46.2143 111.174 53.8502C114.373 61.4862 107.509 64.065 103.676 64.3999L58.689 67.9165Z"
                      Fill="{Binding IsLeftTriggerActive, Converter={StaticResource TriggerFillBrush}}"
                      Stroke="{Binding IsLeftTriggerActive, Converter={StaticResource InputStrokeBrush}}"
                      StrokeThickness="3"
                      StrokeLineJoin="Round" />
            </Viewbox>
            <Viewbox Canvas.Left="288" Canvas.Top="12" Width="72" Height="48" Stretch="Uniform">
                <Path Data="M58.689 67.9165L5.20399 73.9448C0.805227 74.4406 0.705254 71.4721 1.20511 69.9259C3.20455 62.3904 8.20315 44.4057 12.202 32.7509C17.2006 18.1822 32.6963 9.13966 38.6946 6.62782C44.6929 4.116 57.6893 2.10654 72.6851 1.1018C84.6817 0.298019 89.6803 4.4509 90.6801 6.62782C96.1785 19.187 107.975 46.2143 111.174 53.8502C114.373 61.4862 107.509 64.065 103.676 64.3999L58.689 67.9165Z"
                      Fill="{Binding IsRightTriggerActive, Converter={StaticResource TriggerFillBrush}}"
                      Stroke="{Binding IsRightTriggerActive, Converter={StaticResource InputStrokeBrush}}"
                      StrokeThickness="3"
                      StrokeLineJoin="Round"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <ScaleTransform ScaleX="-1" />
                    </Path.RenderTransform>
                </Path>
            </Viewbox>

            <Path Data="M351,92.4 C350,89.8 347.9,87.8 345.3,86.9 L312.8,74.6 C307.3,72.5 301.3,72.9 296.1,75.6 L287.7,80 L212.3,80 L204,75.6 C198.8,72.9 192.7,72.5 187.3,74.6 L154.7,86.9 C152.1,87.9 150,89.9 149,92.4 L146.5,98.6 L146.5,133 L353.5,133 L353.5,98.7 Z"
                  Fill="{StaticResource SurfaceFill}"
                  Stroke="{StaticResource LineBrush}"
                  StrokeThickness="2.2"
                  StrokeLineJoin="Round" />
            <Path Data="M146.5,98.6 L149,92.4 C150,89.8 152.1,87.9 154.7,86.9 L187.3,74.6 C192.8,72.5 198.8,72.9 204,75.6 L212.3,80 H230 L224,133 H146.5 Z"
                  Fill="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputStrokeBrush}}"
                  StrokeThickness="2.2"
                  StrokeLineJoin="Round" />
            <Path Data="M353.5,98.7 L351,92.4 C350,89.8 347.9,87.9 345.3,86.9 L312.8,74.6 C307.3,72.5 301.3,72.9 296.1,75.6 L287.7,80 H270 L276,133 H353.5 Z"
                  Fill="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputFillBrush}}"
                  Stroke="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputStrokeBrush}}"
                  StrokeThickness="2.2"
                  StrokeLineJoin="Round" />

            <Path Data="M360,104.4 C358.7,101.6 356.3,99.5 353.4,98.5 L315.1,85.7 C309.1,83.7 302.6,85.5 298.4,90.2 L278.5,113 C277.3,114.4 275.5,115.2 273.6,115.3 H226.4 C224.5,115.3 222.7,114.5 221.5,113 L201.6,90.1 C197.5,85.4 190.9,83.6 184.9,85.6 L146.6,98.4 C143.7,99.4 141.3,101.5 140,104.3 C128.3,129.3 73.8,253.1 130.1,266.3 C133.5,267.1 137.1,266.1 139.6,263.5 L180.1,223 C183.6,219.5 188.4,217.5 193.4,217.5 H306.6 C311.6,217.5 316.4,219.5 319.9,223 L360.4,263.5 C362.9,266 366.5,267 369.9,266.3 C426.3,253.2 371.7,129.5 360,104.4 Z"
                  Fill="{StaticResource ControllerFill}"
                  Stroke="{StaticResource LineBrush}"
                  StrokeThickness="2.4"
                  StrokeLineJoin="Round" />

            <Ellipse Canvas.Left="154.8" Canvas.Top="109.4" Width="44.4" Height="44.4" Fill="{StaticResource SurfaceFill}" Stroke="{StaticResource MutedLineBrush}" StrokeThickness="1.8" />
            <Ellipse Canvas.Left="163.2" Canvas.Top="117.8" Width="27" Height="27" Fill="{StaticResource StickDotLeft}">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="{Binding CompactLeftStickDotX}" Y="{Binding CompactLeftStickDotY}" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Canvas.Left="266.8" Canvas.Top="154" Width="44.4" Height="44.4" Fill="{StaticResource SurfaceFill}" Stroke="{StaticResource MutedLineBrush}" StrokeThickness="1.8" />
            <Ellipse Canvas.Left="275.2" Canvas.Top="162.4" Width="27" Height="27" Fill="{StaticResource StickDotRight}">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="{Binding CompactRightStickDotX}" Y="{Binding CompactRightStickDotY}" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse Canvas.Left="188.5" Canvas.Top="155" Width="51" Height="51" Fill="Transparent" Stroke="{StaticResource MutedLineBrush}" StrokeThickness="1.5" />
            <Path Data="M207,160 L219,160 L219,173 L232,173 L232,185 L219,185 L219,198 L207,198 L207,185 L194,185 L194,173 L207,173 Z"
                  Fill="{StaticResource SurfaceFill}"
                  Stroke="{StaticResource LineBrush}"
                  StrokeThickness="2"
                  StrokeLineJoin="Round" />
            <Path Data="M209,162 L217,162 L217,175 L209,175 Z" Fill="{Binding State.Buttons.DpadUp, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadUp, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="1.6" />
            <Path Data="M196,175 L209,175 L209,183 L196,183 Z" Fill="{Binding State.Buttons.DpadLeft, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadLeft, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="1.6" />
            <Path Data="M217,175 L230,175 L230,183 L217,183 Z" Fill="{Binding State.Buttons.DpadRight, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadRight, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="1.6" />
            <Path Data="M209,183 L217,183 L217,196 L209,196 Z" Fill="{Binding State.Buttons.DpadDown, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.DpadDown, Converter={StaticResource ActiveOnlyStrokeBrush}}" StrokeThickness="1.6" />

            <Ellipse Canvas.Left="223.5" Canvas.Top="124.9" Width="13.2" Height="13.2" Fill="{Binding State.Buttons.Back, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.Back, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="1.8" />
            <Ellipse Canvas.Left="237.1" Canvas.Top="84.5" Width="26" Height="26" Fill="{Binding State.Buttons.Guide, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.Guide, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Path Data="M253.5,90.5 L243.1,100.9 M243.2,90.5 L253.6,100.9" Stroke="{StaticResource LineBrush}" StrokeThickness="2.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
            <Ellipse Canvas.Left="263.3" Canvas.Top="124.9" Width="13.2" Height="13.2" Fill="{Binding State.Buttons.Start, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.Start, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="1.8" />

            <Ellipse Canvas.Left="310.5" Canvas.Top="99" Width="25" Height="25" Fill="{Binding State.Buttons.North, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.North, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="330.6" Canvas.Top="119" Width="25" Height="25" Fill="{Binding State.Buttons.East, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.East, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="290.4" Canvas.Top="119" Width="25" Height="25" Fill="{Binding State.Buttons.West, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.West, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Ellipse Canvas.Left="310.5" Canvas.Top="139.1" Width="25" Height="25" Fill="{Binding State.Buttons.South, Converter={StaticResource InputFillBrush}}" Stroke="{Binding State.Buttons.South, Converter={StaticResource InputStrokeBrush}}" StrokeThickness="2" />
            <Label Canvas.Left="310.5" Canvas.Top="99" Width="25" Height="25" Content="{Binding NorthLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="330.6" Canvas.Top="119" Width="25" Height="25" Content="{Binding EastLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="290.4" Canvas.Top="119" Width="25" Height="25" Content="{Binding WestLabel}" Style="{StaticResource MapLabel}" />
            <Label Canvas.Left="310.5" Canvas.Top="139.1" Width="25" Height="25" Content="{Binding SouthLabel}" Style="{StaticResource MapLabel}" />
        </Canvas>
    </Viewbox>
</UserControl>
