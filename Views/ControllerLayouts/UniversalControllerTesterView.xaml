<UserControl x:Class="GamepadTester.Views.ControllerLayouts.UniversalControllerTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GamepadTester.Converters"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="ControllerFill" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#202B39" Offset="0" />
            <GradientStop Color="#151A22" Offset="0.55" />
            <GradientStop Color="#10151C" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SurfaceFill" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#303A49" Offset="0" />
            <GradientStop Color="#1B222D" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="LineBrush" Color="{DynamicResource TextColor}" />
        <SolidColorBrush x:Key="MutedLineBrush" Color="{DynamicResource TextColorDarker}" />
        <SolidColorBrush x:Key="InputIdleFill" Color="Transparent" />
        <SolidColorBrush x:Key="InputActiveFill" Color="#6631C48D" />
        <SolidColorBrush x:Key="InputActiveStroke" Color="#64F0B7" />
        <SolidColorBrush x:Key="TriggerTrack" Color="{DynamicResource ControlBackgroundColorDark}" />
        <SolidColorBrush x:Key="StickDotLeft" Color="#4CC9F0" />
        <SolidColorBrush x:Key="StickDotRight" Color="#F7B955" />

        <converters:BoolToBrushConverter x:Key="InputFillBrush"
                                         FalseBrush="{StaticResource InputIdleFill}"
                                         TrueBrush="{StaticResource InputActiveFill}" />
        <converters:BoolToBrushConverter x:Key="InputStrokeBrush"
                                         FalseBrush="{StaticResource LineBrush}"
                                         TrueBrush="{StaticResource InputActiveStroke}" />
        <converters:BoolToBrushConverter x:Key="ActiveOnlyStrokeBrush"
                                         FalseBrush="{StaticResource InputIdleFill}"
                                         TrueBrush="{StaticResource InputActiveStroke}" />

        <Style x:Key="MapLabel" TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SmallMapText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="760" Height="500">
            <Canvas Canvas.Left="138" Canvas.Top="12">
                <Path Data="M58.689 67.9165L5.20399 73.9448C0.805227 74.4406 0.705254 71.4721 1.20511 69.9259C3.20455 62.3904 8.20315 44.4057 12.202 32.7509C17.2006 18.1822 32.6963 9.13966 38.6946 6.62782C44.6929 4.116 57.6893 2.10654 72.6851 1.1018C84.6817 0.298019 89.6803 4.4509 90.6801 6.62782C96.1785 19.187 107.975 46.2143 111.174 53.8502C114.373 61.4862 107.509 64.065 103.676 64.3999L58.689 67.9165Z"
                      Fill="{Binding IsLeftTriggerActive, Converter={StaticResource InputFillBrush}}"
                      Stroke="{Binding IsLeftTriggerActive, Converter={StaticResource InputStrokeBrush}}"
                      StrokeThickness="1.6"
                      StrokeLineJoin="Round">
                    <Path.RenderTransform>
                        <ScaleTransform ScaleX="1.08" ScaleY="1.08" />
                    </Path.RenderTransform>
                </Path>
                <TextBlock Text="{Binding LeftTriggerPercent, StringFormat={}{0}%}"
                           Canvas.Left="36"
                           Canvas.Top="26"
                           Width="50"
                           Style="{StaticResource SmallMapText}" />
                <Border Canvas.Left="0"
                        Canvas.Top="92"
                        Width="122"
                        Height="6"
                        CornerRadius="3"
                        Background="#151922"
                        BorderBrush="{StaticResource MutedLineBrush}"
                        BorderThickness="0.5"
                        ClipToBounds="True">
                    <Rectangle HorizontalAlignment="Left"
                               Width="{Binding LeftTriggerThinMapWidth}"
                               RadiusX="3"
                               RadiusY="3"
                               Fill="{StaticResource InputActiveStroke}"
                               Opacity="0.86" />
                </Border>
            </Canvas>

            <Canvas Canvas.Left="500" Canvas.Top="12">
                <Path Data="M58.689 67.9165L5.20399 73.9448C0.805227 74.4406 0.705254 71.4721 1.20511 69.9259C3.20455 62.3904 8.20315 44.4057 12.202 32.7509C17.2006 18.1822 32.6963 9.13966 38.6946 6.62782C44.6929 4.116 57.6893 2.10654 72.6851 1.1018C84.6817 0.298019 89.6803 4.4509 90.6801 6.62782C96.1785 19.187 107.975 46.2143 111.174 53.8502C114.373 61.4862 107.509 64.065 103.676 64.3999L58.689 67.9165Z"
                      Fill="{Binding IsRightTriggerActive, Converter={StaticResource InputFillBrush}}"
                      Stroke="{Binding IsRightTriggerActive, Converter={StaticResource InputStrokeBrush}}"
                      StrokeThickness="1.6"
                      StrokeLineJoin="Round">
                    <Path.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="-1.08" ScaleY="1.08" />
                            <TranslateTransform X="122" />
                        </TransformGroup>
                    </Path.RenderTransform>
                </Path>
                <TextBlock Text="{Binding RightTriggerPercent, StringFormat={}{0}%}"
                           Canvas.Left="36"
                           Canvas.Top="26"
                           Width="50"
                           Style="{StaticResource SmallMapText}" />
                <Border Canvas.Left="0"
                        Canvas.Top="92"
                        Width="122"
                        Height="6"
                        CornerRadius="3"
                        Background="#151922"
                        BorderBrush="{StaticResource MutedLineBrush}"
                        BorderThickness="0.5"
                        ClipToBounds="True">
                    <Rectangle HorizontalAlignment="Left"
                               Width="{Binding RightTriggerThinMapWidth}"
                               RadiusX="3"
                               RadiusY="3"
                               Fill="{StaticResource InputActiveStroke}"
                               Opacity="0.86" />
                </Border>
            </Canvas>

            <Canvas Canvas.Left="80" Canvas.Top="132" Width="600" Height="400">
