                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.North, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.North, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding NorthLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.Guide, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.Guide, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding GuideButtonLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.LeftShoulder, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.LeftShoulder, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding LeftShoulderLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.RightShoulder, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.RightShoulder, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding RightShoulderLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding IsLeftTriggerActive, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding IsLeftTriggerActive, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding LeftTriggerLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding IsRightTriggerActive, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding IsRightTriggerActive, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding RightTriggerLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.LeftStick, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.LeftStick, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding LeftStickButtonLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.RightStick, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.RightStick, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding RightStickButtonLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.Back, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.Back, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding BackButtonLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.Start, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.Start, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding StartButtonLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.DpadUp, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.DpadUp, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding DpadUpLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.DpadDown, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.DpadDown, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding DpadDownLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.DpadLeft, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.DpadLeft, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding DpadLeftLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                            <Border Style="{StaticResource CompactInputPill}" Background="{Binding State.Buttons.DpadRight, Converter={StaticResource InputFillBrush}}" TextElement.Foreground="{Binding State.Buttons.DpadRight, Converter={StaticResource PillTextBrush}}"><TextBlock Text="{Binding DpadRightLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                        </UniformGrid>
                                        <StackPanel Margin="0,14,0,0"
