                                                   Style="{StaticResource DashboardTitle}" />
                                        <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,10" />
                                        <TextBlock Text="{DynamicResource LOCGT_LatencySimpleHelp}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>

                                    <Grid Grid.Row="1"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,18,0,0">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PollingRateCurrentLabel}"
                                                       FontSize="82"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center" />
                                            <TextBlock Text="{Binding PollingJitterLabel, StringFormat=Jitter {0}}"
                                                       FontFamily="Consolas"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextAlignment="Center"
                                                       Margin="0,6,0,0" />
                                            <Grid Width="620"
                                                  Height="176"
                                                  Margin="0,18,0,0"
                                                  ClipToBounds="False">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="540" />
                                                    <ColumnDefinition Width="20" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="132" />
                                                    <RowDefinition Height="28" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="1000 Hz"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Top"
                                                           Margin="0,-2,10,0"
                                                           Opacity="0.85" />
                                                <TextBlock Text="500 Hz"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"
                                                           Opacity="0.7" />
                                                <TextBlock Text="0 Hz"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Bottom"
                                                           Margin="0,0,10,-2"
                                                           Opacity="0.85" />

                                                <Canvas Grid.Column="1" Width="540" Height="132" ClipToBounds="True">
                                                        <Rectangle Width="540"
                                                                   Height="132"
                                                                   RadiusX="7"
                                                                   RadiusY="7"
                                                                   Fill="#10151C"
                                                                   Opacity="0.62" />
                                                        <Line X1="0" Y1="33" X2="540" Y2="33"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              StrokeDashArray="2 5"
                                                              Opacity="0.18" />
                                                        <Line X1="0" Y1="66" X2="540" Y2="66"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              StrokeDashArray="2 5"
                                                              Opacity="0.22" />
                                                        <Line X1="0" Y1="99" X2="540" Y2="99"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              StrokeDashArray="2 5"
                                                              Opacity="0.18" />
                                                        <Line X1="90" Y1="0" X2="90" Y2="132"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              Opacity="0.08" />
                                                        <Line X1="180" Y1="0" X2="180" Y2="132"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              Opacity="0.08" />
                                                        <Line X1="270" Y1="0" X2="270" Y2="132"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              Opacity="0.08" />
                                                        <Line X1="360" Y1="0" X2="360" Y2="132"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              Opacity="0.08" />
                                                        <Line X1="450" Y1="0" X2="450" Y2="132"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              Opacity="0.08" />
                                                        <Line X1="0" Y1="131" X2="540" Y2="131"
                                                              Stroke="{StaticResource TextMutedBrush}"
                                                              StrokeThickness="1"
                                                              Opacity="0.28" />
                                                        <Polyline Points="{Binding LatencyRateGraphPoints}"
                                                                  Stroke="{StaticResource ActiveBrush}"
                                                                  StrokeThickness="3.2"
                                                                  StrokeLineJoin="Round"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round" />
                                                    </Canvas>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="1"
                                                           Text="{DynamicResource LOCGT_PollingLatencyTitle}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"
                                                           Opacity="0.75" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2"
                                            Background="Transparent"
                                            Padding="0"
                                            Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="{Binding StartLatencyButtonLabel}"
                                                    Command="{Binding StartLatencyTestCommand}"
                                                    Height="42"
                                                    MinWidth="170"
                                                    Margin="0,0,10,0" />
                                            <Button Content="{DynamicResource LOCGT_ResetLatency}"
                                                    Command="{Binding ResetLatencyCommand}"
                                                    Height="42"
                                                    MinWidth="150"
                                                    Margin="0,0,10,0" />
                                            <Button Content="{DynamicResource LOCGT_ExportLatency}"
                                                    Command="{Binding ExportLatencyCommand}"
                                                    Height="42"
                                                    MinWidth="150" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="22,0,0,0">
                                    <Border BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Background="{StaticResource PanelBrush}"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource LOCGT_DeviceConnected}"
                                                       Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding DeviceModelLabel}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <UniformGrid Columns="2" Margin="0,0,0,12">
                                        <Border Style="{StaticResource DashboardMetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_MaxRate}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding PollingRateMaxValueLabel}" Style="{StaticResource MetricValue}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DashboardMetricTile}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_AverageRate}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding PollingRateAverageValueLabel}" Style="{StaticResource MetricValue}" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <UniformGrid Columns="3" Margin="0,0,0,12">
                                        <Border Style="{StaticResource DashboardMetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_LatencySamples}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding LatencySampleCountLabel}" Style="{StaticResource MetricValue}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DashboardMetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_LatencyRange}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding LatencyRangeLabel}" Style="{StaticResource MetricValue}" FontSize="13" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DashboardMetricTile}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_LatencyDuration}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding LatencyTestDurationLabel}" Style="{StaticResource MetricValue}" FontSize="13" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Style="{StaticResource DashboardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource LOCGT_EstimatedDelay}" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding EstimatedDelayLabel}"
                                                       FontSize="34"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding LatencyStatusLabel}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding LatencyConfidenceLabel}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding InputEventLatencyAverageLabel}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>

                                <Border Style="{StaticResource DashboardPanel}" Margin="0,0,0,12">
                                    <StackPanel>
                                            <TextBlock Text="{DynamicResource LOCGT_PerformanceReference}"
                                                       Style="{StaticResource MetricLabel}"
                                                       Margin="0,0,0,10" />
                                            <TextBlock Text="USB / 2.4G  ~1000 Hz" FontWeight="SemiBold" />
                                            <TextBlock Text="Bluetooth  125 - 250 Hz" FontWeight="SemiBold" Margin="0,8,0,0" />
                                            <TextBlock Text="{DynamicResource LOCGT_LatencyHelp}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource LOCGT_TabInputLog}">
                    <Grid Margin="0,10,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource DashboardPanel}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCGT_TabInputLog}" Style="{StaticResource DashboardTitle}" />
                                <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsInputLogEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{DynamicResource LOCGT_EnableInputLog}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <Button Content="{DynamicResource LOCGT_ExportInputLog}"
                                                Command="{Binding ExportInputLogCommand}"
                                                Height="34"
                                                MinWidth="150"
                                                Margin="0,0,8,0" />
                                        <Button Content="{DynamicResource LOCGT_ResetInputLog}"
                                                Command="{Binding ResetInputLogCommand}"
                                                Height="34"
                                                MinWidth="110" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding InputLogExportStatusLabel}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource DashboardPanel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{DynamicResource LOCGT_InputHistory}" Style="{StaticResource DashboardTitle}" />
                                <Border Grid.Row="1" Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,12" />
                                <Border Grid.Row="2"
                                        Visibility="{Binding IsInputLogDisabled, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LOCGT_InputLogDisabled}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="{DynamicResource LOCGT_InputLogDisabledHelp}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="0,10,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding InputHistory}"
                                         Background="{DynamicResource ListBoxBackgroundBrush}"
                                         BorderBrush="{StaticResource LineBrush}"
                                         Visibility="{Binding IsInputLogEnabled, Converter={StaticResource BoolToVisibility}}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,6" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12,9"
                                                    Background="{StaticResource PanelBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TimeLabel}"
                                                               FontFamily="Consolas"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" />
                                                    <Border x:Name="InputKeyBox"
                                                            Grid.Column="1"
                                                            Background="{StaticResource IdleBrush}"
                                                            BorderBrush="{StaticResource LineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Height="34"
                                                            Padding="8,0"
                                                            TextElement.Foreground="{DynamicResource TextBrush}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding InputName}"
                                                                   FontWeight="SemiBold"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Margin="12,0,12,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DetailLabel}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <Border x:Name="StateBadge"
                                                            Grid.Column="3"
                                                            CornerRadius="10"
                                                            Padding="10,4"
                                                            Background="#8A3A16"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding State}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FFF4E8" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Pressed">
                                                    <Setter TargetName="InputKeyBox" Property="Background" Value="#1D6B50" />
                                                    <Setter TargetName="InputKeyBox" Property="BorderBrush" Value="#1D6B50" />
                                                    <Setter TargetName="InputKeyBox" Property="TextElement.Foreground" Value="#FFFFFF" />
                                                    <Setter TargetName="StateBadge" Property="Background" Value="#1D6B50" />
                                                    <Setter TargetName="StateBadge" Property="TextElement.Foreground" Value="#EFFFF7" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Released">
                                                    <Setter TargetName="InputKeyBox" Property="Background" Value="#1F5E9D" />
                                                    <Setter TargetName="InputKeyBox" Property="BorderBrush" Value="#1F5E9D" />
                                                    <Setter TargetName="InputKeyBox" Property="TextElement.Foreground" Value="#FFFFFF" />
                                                    <Setter TargetName="StateBadge" Property="Background" Value="#1F5E9D" />
                                                    <Setter TargetName="StateBadge" Property="TextElement.Foreground" Value="#EEF7FF" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Changed">
                                                    <Setter TargetName="InputKeyBox" Property="Background" Value="#A84B37" />
                                                    <Setter TargetName="InputKeyBox" Property="BorderBrush" Value="#A84B37" />
                                                    <Setter TargetName="InputKeyBox" Property="TextElement.Foreground" Value="#FFFFFF" />
                                                    <Setter TargetName="StateBadge" Property="Background" Value="#A84B37" />
                                                    <Setter TargetName="StateBadge" Property="TextElement.Foreground" Value="#FFF2F0" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource LOCGT_TabDeviceInfo}">
                    <Grid Margin="0,10,12,0">
                        <Border Style="{StaticResource DashboardPanel}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
                                    <TextBlock Text="{DynamicResource LOCGT_DeviceSection}" Style="{StaticResource DashboardTitle}" />
                                    <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{DynamicResource LOCGT_Name}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding State.ControllerName}" Margin="0,0,0,10" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{DynamicResource LOCGT_DetectedModel}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceModelLabel}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="3" Text="{DynamicResource LOCGT_VidPid}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DeviceIdLabel}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="4" Text="{DynamicResource LOCGT_Layout}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding State.Layout}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="5" Text="{DynamicResource LOCGT_Backend}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding BackendLabel}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="6" Text="{DynamicResource LOCGT_MappingStatus}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MappingStatusLabel}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="7" Text="{DynamicResource LOCGT_InputApi}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding DeviceApiLabel}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="8" Text="{DynamicResource LOCGT_Capabilities}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DeviceCapabilitiesLabel}" Margin="0,0,0,10" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="9" Text="{DynamicResource LOCGT_ExtraControls}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding ExtraButtonDetailLabel}" Margin="0,0,0,10" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="10" Text="{DynamicResource LOCGT_Rumble}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding DeviceRumbleCapabilityLabel}" Margin="0,0,0,10" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="11" Text="{DynamicResource LOCGT_Notes}" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="{DynamicResource LOCGT_DeviceNotes}" TextWrapping="Wrap" />
                                <Grid Grid.Row="12" Grid.ColumnSpan="2" Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{DynamicResource LOCGT_ExportCompatibilityReport}"
                                            Command="{Binding ExportCompatibilityReportCommand}"
                                            Height="36"
                                            MinWidth="210" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CompatibilityReportStatusLabel}"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                </TabControl>

                <Grid Grid.Row="0"
                      Panel.ZIndex="20"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,7,132,0"
                      Visibility="{Binding IsControllerSelectorVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource LOCGT_Device}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <ComboBox Grid.Column="1"
                              Width="320"
                              Height="30"
                              MaxDropDownHeight="320"
                              ItemsSource="{Binding Controllers}"
                              SelectedItem="{Binding SelectedController, Mode=TwoWay}"
                              IsDropDownOpen="{Binding IsControllerSelectorOpen, Mode=TwoWay}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="{StaticResource PillIdleTextBrush}" />
                                <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter Property="Padding" Value="8,4" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{StaticResource PillIdleTextBrush}"
                                           FontWeight="SemiBold"
                                           Margin="4,1"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Border Grid.Row="1"
                        Margin="2,10,2,0"
                        Padding="12,8"
                        CornerRadius="6"
                        Background="{StaticResource IdleBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        Visibility="{Binding IsFullscreenSimplifiedMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding FullscreenNavigationHint}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PillIdleTextBrush}"
                               HorizontalAlignment="Center" />
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
