                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button Content="{DynamicResource LOCGT_ResetSticks}"
                                                Command="{Binding ResetDiagnosticsCommand}"
