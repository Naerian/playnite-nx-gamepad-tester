                                                Height="34"
                                                MinWidth="130" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
