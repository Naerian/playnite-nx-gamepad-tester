                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="{DynamicResource LOCGT_LeftStick}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding LeftRangeQualityLabel}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" />
