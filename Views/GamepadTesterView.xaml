<UserControl x:Class="GamepadTester.Views.GamepadTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GamepadTester.Converters"
             xmlns:layouts="clr-namespace:GamepadTester.Views.ControllerLayouts">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="{DynamicResource ControlBackgroundColorDark}" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="{DynamicResource ControlBackgroundColorDark}" />
        <SolidColorBrush x:Key="LineBrush" Color="{DynamicResource PopupBorderColor}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextColorDarker}" />
        <SolidColorBrush x:Key="ActiveBrush" Color="#31C48D" />
        <SolidColorBrush x:Key="ActivePillTextBrush" Color="#07130F" />
        <SolidColorBrush x:Key="PillIdleTextBrush" Color="{DynamicResource TextColor}" />
        <SolidColorBrush x:Key="IdleBrush" Color="{DynamicResource ControlBackgroundColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F7B955" />
        <SolidColorBrush x:Key="SwitchAccentBrush" Color="#E60012" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:BoolToBrushConverter x:Key="InputFillBrush"
                                         FalseBrush="{StaticResource IdleBrush}"
                                         TrueBrush="{StaticResource ActiveBrush}" />
        <converters:BoolToBrushConverter x:Key="PillTextBrush"
                                         FalseBrush="{StaticResource PillIdleTextBrush}"
                                         TrueBrush="{StaticResource ActivePillTextBrush}" />

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="DashboardPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource PillIdleTextBrush}" />
        </Style>

        <Style x:Key="DashboardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PillIdleTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="DashboardMetricTile" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource IdleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="MinHeight" Value="66" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource PillIdleTextBrush}" />
        </Style>

        <Style x:Key="SubtleVerticalSeparator" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Background" Value="{StaticResource LineBrush}" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="18,0" />
        </Style>

        <Style x:Key="SubtleHorizontalSeparator" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource LineBrush}" />
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Margin" Value="12,2,12,10" />
        </Style>

        <Style x:Key="InputPill" TargetType="Border">
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style x:Key="CompactInputPill" TargetType="Border" BasedOn="{StaticResource InputPill}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="TextElement.FontSize" Value="12" />
        </Style>

        <Style x:Key="CheckPill" TargetType="Border" BasedOn="{StaticResource InputPill}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="GuidedInputChip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ActiveBrush}" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource ActivePillTextBrush}" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.86"
                                             To="1"
                                             Duration="0:0:0.85" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="4,10,0,4" />
        </Style>

        <Style x:Key="SideNavigationTabItem" TargetType="TabItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{StaticResource PillIdleTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource IdleBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LineBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource IdleBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ActiveBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideNavigationTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SideNavigationTabItem}" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="166" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="0,0,1,0"
                                    Padding="0,6,12,6"
                                    Margin="0,0,14,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="Transparent"
                                    Padding="0">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12" TextElement.Foreground="{StaticResource PillIdleTextBrush}">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0"
                CornerRadius="0"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        MaxWidth="620"
                        Padding="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsNoControllerVisible, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCGT_NoControllerDetected}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Text="{DynamicResource LOCGT_NoControllerDetectedHelp}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                            Visibility="{Binding HasController, Converter={StaticResource BoolToVisibility}}">
                <TabItem Header="{DynamicResource LOCGT_TabTest}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="0,10,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.75*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource DashboardPanel}" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{DynamicResource LOCGT_TabTest}" Style="{StaticResource DashboardTitle}" />
                                                <StackPanel Grid.Column="1"
                                                            MaxWidth="360"
                                                            Margin="18,0,0,0"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding DeviceModelLabel}"
                                                               FontWeight="SemiBold"
                                                               TextAlignment="Right"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding DeviceIdLabel}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="11"
                                                               TextAlignment="Right"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                            <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,6" />
                                        </StackPanel>

                                        <Grid Grid.Row="1"
                                              MinHeight="370"
                                              Width="{Binding ControllerVisualWidth}"
                                              Height="{Binding ControllerVisualHeight}"
                                              ClipToBounds="True"
                                              Cursor="Arrow"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <layouts:DualSenseControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                                   Height="{Binding ControllerVisualHeight}"
                                                                                   Visibility="{Binding IsDualSenseLayout, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:XboxControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                              Height="{Binding ControllerVisualHeight}"
                                                                              Visibility="{Binding IsXboxOneVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:XboxSeriesControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                                    Height="{Binding ControllerVisualHeight}"
                                                                                    Visibility="{Binding IsXboxSeriesVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:PlayStationControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                                      Height="{Binding ControllerVisualHeight}"
                                                                                      Visibility="{Binding IsPlayStationVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:SwitchProControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                                   Height="{Binding ControllerVisualHeight}"
                                                                                   Visibility="{Binding IsSwitchProVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:EightBitDoUltimateTesterView Width="{Binding ControllerVisualWidth}"
                                                                                  Height="{Binding ControllerVisualHeight}"
                                                                                  Visibility="{Binding IsEightBitDoUltimateVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:EightBitDoProTesterView Width="{Binding ControllerVisualWidth}"
                                                                             Height="{Binding ControllerVisualHeight}"
                                                                             Visibility="{Binding IsEightBitDoProVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:SteamControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                               Height="{Binding ControllerVisualHeight}"
                                                                               Visibility="{Binding IsSteamControllerVisualScheme, Converter={StaticResource BoolToVisibility}}" />
                                            <layouts:UniversalControllerTesterView Width="{Binding ControllerVisualWidth}"
                                                                                   Height="{Binding ControllerVisualHeight}"
                                                                                   Visibility="{Binding IsUniversalControllerArtwork, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>

                                        <StackPanel Grid.Row="2"
                                                    Width="260"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Center"
                                                    Visibility="{Binding IsVisualSchemeSelectorVisible, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{DynamicResource LOCGT_VisualScheme}"
                                                       Style="{StaticResource MetricLabel}"
                                                       TextAlignment="Center"
                                                       Margin="0,0,0,6" />
                                            <ComboBox ItemsSource="{Binding VisualSchemeOptions}"
                                                      SelectedValue="{Binding SelectedVisualSchemeKey, Mode=TwoWay}"
                                                      SelectedValuePath="Key"
                                                      Foreground="{StaticResource PillIdleTextBrush}"
                                                      Background="{StaticResource IdleBrush}"
                                                      Height="28"
                                                      MaxDropDownHeight="240">
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Foreground" Value="{StaticResource PillIdleTextBrush}" />
                                                        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                                                        <Setter Property="TextElement.Foreground" Value="{StaticResource PillIdleTextBrush}" />
                                                        <Setter Property="Padding" Value="8,5" />
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource PillIdleTextBrush}"
                                                                   Margin="4,1"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <Border Style="{StaticResource DashboardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource LOCGT_ControllerHealth}" Style="{StaticResource DashboardTitle}" />
                                            <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,12" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding HealthScoreDisplayLabel}" FontSize="36" FontWeight="SemiBold" />
                                                <StackPanel Grid.Column="1" Margin="16,6,0,0">
                                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding HealthDisplayProgress, Mode=OneWay}" Height="12" />
                                                    <TextBlock Text="{Binding HealthLabel}" Margin="0,8,0,0" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding HealthSummaryLabel}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,12,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding HealthConfidenceLabel}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <UniformGrid Columns="2" Margin="0,0,0,4">
                                        <Border Style="{StaticResource DashboardMetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_ActiveInputs}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding ActiveButtonCount}" Style="{StaticResource MetricValue}" />
                                                <TextBlock Text="{DynamicResource LOCGT_ButtonsCurrentlyPressed}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DashboardMetricTile}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_CenterDrift}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding MaxDriftLabel}" Style="{StaticResource MetricValue}" />
                                                <TextBlock Text="{DynamicResource LOCGT_Current}" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DashboardMetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding LeftTriggerLabel}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding LeftTriggerPercent, StringFormat={}{0}%}" Style="{StaticResource MetricValue}" />
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding LeftTriggerPercent, Mode=OneWay}" Height="7" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource DashboardMetricTile}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding RightTriggerLabel}" Style="{StaticResource MetricLabel}" />
                                                <TextBlock Text="{Binding RightTriggerPercent, StringFormat={}{0}%}" Style="{StaticResource MetricValue}" />
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding RightTriggerPercent, Mode=OneWay}" Height="7" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Style="{StaticResource DashboardPanel}">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource LOCGT_Sticks}" Style="{StaticResource DashboardTitle}" />
                                            <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,10" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Margin="0,0,16,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="128" Height="128" HorizontalAlignment="Center">
                                                        <Grid.LayoutTransform>
                                                            <ScaleTransform ScaleX="0.78" ScaleY="0.78" />
                                                        </Grid.LayoutTransform>
                                                        <Ellipse Stroke="{StaticResource LineBrush}" StrokeThickness="2" Fill="#11151B" />
                                                        <Ellipse Width="16" Height="16" Stroke="#384252" StrokeThickness="1" />
                                                        <Line X1="64" X2="64" Y1="12" Y2="116" Stroke="#4D5564" />
                                                        <Line X1="12" X2="116" Y1="64" Y2="64" Stroke="#4D5564" />
                                                        <Ellipse Width="26" Height="26" Fill="#4CC9F0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform X="{Binding LeftStickDotX}" Y="{Binding LeftStickDotY}" />
                                                            </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Margin="22,6,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{DynamicResource LOCGT_LeftStick}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding LeftStickVector}" Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" />
                                                        <TextBlock Text="{Binding LeftStickDriftPercent, StringFormat=Drift: {0}%}" Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding LeftStickDriftStatus}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="16,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="128" Height="128" HorizontalAlignment="Center">
                                                        <Grid.LayoutTransform>
                                                            <ScaleTransform ScaleX="0.78" ScaleY="0.78" />
                                                        </Grid.LayoutTransform>
                                                        <Ellipse Stroke="{StaticResource LineBrush}" StrokeThickness="2" Fill="#11151B" />
                                                        <Ellipse Width="16" Height="16" Stroke="#384252" StrokeThickness="1" />
                                                        <Line X1="64" X2="64" Y1="12" Y2="116" Stroke="#4D5564" />
                                                        <Line X1="12" X2="116" Y1="64" Y2="64" Stroke="#4D5564" />
                                                        <Ellipse Width="26" Height="26" Fill="#F7B955" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform X="{Binding RightStickDotX}" Y="{Binding RightStickDotY}" />
                                                            </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Margin="22,6,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{DynamicResource LOCGT_RightStick}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding RightStickVector}" Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" />
                                                        <TextBlock Text="{Binding RightStickDriftPercent, StringFormat=Drift: {0}%}" Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding RightStickDriftStatus}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource DashboardPanel}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCGT_TestDetails}" Style="{StaticResource DashboardTitle}" />
                                        <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,12" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource LOCGT_GuidedTest}" FontWeight="SemiBold" />
                                                <TextBlock Text="{DynamicResource LOCGT_GuidedTestHelp}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCGT_OpenGuidedTest}"
                                                    Command="{Binding OpenGuidedTestCommand}"
                                                    Height="40"
                                                    MinWidth="142"
                                                    Margin="16,0,0,0"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                        <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,12,0,12" />
                                        <TextBlock Text="{Binding HealthDriftFactorLabel}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding HealthRangeFactorLabel}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding HealthCoverageFactorLabel}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding LeftStickCircularCoverageLabel}" TextWrapping="Wrap" Margin="0,16,0,0" />
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding LeftStickCircularCoveragePercent, Mode=OneWay}" Height="8" Margin="0,6,0,8" />
                                        <TextBlock Text="{Binding RightStickCircularCoverageLabel}" TextWrapping="Wrap" />
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding RightStickCircularCoveragePercent, Mode=OneWay}" Height="8" Margin="0,6,0,0" />
                                        <UniformGrid Columns="2" Margin="0,18,0,0" HorizontalAlignment="Left">
                                            <Button Content="{DynamicResource LOCGT_ResetDiagnostics}"
                                                    Command="{Binding ResetDiagnosticsCommand}"
                                                    Height="36"
                                                    Margin="0,0,8,0"
                                                    MinWidth="130" />
                                            <Button Content="{DynamicResource LOCGT_ExportReport}"
                                                    Command="{Binding ExportReportCommand}"
                                                    Height="36"
                                                    MinWidth="130" />
                                        </UniformGrid>
                                        <TextBlock Text="{Binding ExportReportStatusLabel}" TextWrapping="Wrap" Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
