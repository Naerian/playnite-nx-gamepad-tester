                                                <TextBlock Text="{Binding LeftRangeConfidenceLabel}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                                                <TextBlock Text="{Binding LeftStickAxisRangeLabel}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{DynamicResource LOCGT_RightStick}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding RightRangeQualityLabel}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" />
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding RightRangeDisplayProgress, Mode=OneWay}" Height="10" Margin="0,6,0,8" />
