                                                    Height="34"
                                                    MinWidth="140"
                                                    Margin="0,0,8,0" />
                                            <Button Content="{DynamicResource LOCGT_ResetCalibration}"
                                                    Command="{Binding ResetCalibrationCommand}"
                                                    Height="34"
                                                    MinWidth="140" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource DashboardPanel}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCGT_RangeCalibration}" Style="{StaticResource DashboardTitle}" />
                                        <Border Style="{StaticResource SubtleHorizontalSeparator}" Margin="0,0,0,10" />
                                        <TextBlock Text="{DynamicResource LOCGT_RangeCalibrationHelp}"
