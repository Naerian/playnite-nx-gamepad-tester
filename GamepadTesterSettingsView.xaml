<UserControl x:Class="GamepadTester.GamepadTesterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="640">
    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="28,0,0,12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="CompactTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="96" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SettingsSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GroupBoxBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PopupBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" TextElement.Foreground="{DynamicResource TextBrush}">
            <Border Style="{StaticResource SettingsSection}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCGT_SettingsPlayniteIntegration}" Style="{StaticResource SectionTitle}" />
                    <CheckBox Content="{DynamicResource LOCGT_SettingsShowSidebar}"
                              IsChecked="{Binding Settings.ShowSidebarItem}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsShowSidebarHelp}"
                               Style="{StaticResource MutedText}" />

                    <CheckBox Content="{DynamicResource LOCGT_SettingsShowTopPanel}"
                              IsChecked="{Binding Settings.ShowTopPanelItem}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsShowTopPanelHelp}"
                               Style="{StaticResource MutedText}" />

                    <CheckBox Content="{DynamicResource LOCGT_SettingsFullscreenWindow}"
                              IsChecked="{Binding Settings.UseFullscreenFriendlyWindow}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsFullscreenWindowHelp}"
                               Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCGT_SettingsTestingBehavior}" Style="{StaticResource SectionTitle}" />
                    <CheckBox Content="{DynamicResource LOCGT_SettingsResetOnSwitch}"
                              IsChecked="{Binding Settings.AutoResetDiagnosticsOnControllerChange}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsResetOnSwitchHelp}"
                               Style="{StaticResource MutedText}" />

                    <CheckBox Content="{DynamicResource LOCGT_SettingsShowSingleSelector}"
                              IsChecked="{Binding Settings.ShowDeviceSelectorWhenSingleController}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsShowSingleSelectorHelp}"
                               Style="{StaticResource MutedText}" />

                    <CheckBox Content="{DynamicResource LOCGT_SettingsEnableRumble}"
                              IsChecked="{Binding Settings.EnableRumbleTests}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsEnableRumbleHelp}"
                               Style="{StaticResource MutedText}" />

                    <CheckBox Content="{DynamicResource LOCGT_SettingsInputLogDefault}"
                              IsChecked="{Binding Settings.EnableInputLogByDefault}" />
                    <TextBlock Text="{DynamicResource LOCGT_SettingsInputLogDefaultHelp}"
                               Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSection}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCGT_SettingsThresholds}" Style="{StaticResource SectionTitle}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{DynamicResource LOCGT_SettingsHealthyDeadzone}" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.HealthyDeadzone}" Style="{StaticResource CompactTextBox}" />

                        <TextBlock Grid.Row="1" Text="{DynamicResource LOCGT_SettingsMinorDrift}" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.MinorDriftThreshold}" Style="{StaticResource CompactTextBox}" />

                        <TextBlock Grid.Row="2" Text="{DynamicResource LOCGT_SettingsAttentionDrift}" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.AttentionDriftThreshold}" Style="{StaticResource CompactTextBox}" />

                        <TextBlock Grid.Row="3" Text="{DynamicResource LOCGT_SettingsStickEdge}" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.StickEdgeThreshold}" Style="{StaticResource CompactTextBox}" />

                        <TextBlock Grid.Row="4" Text="{DynamicResource LOCGT_SettingsTriggerFullPress}" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Settings.TriggerFullPressThreshold}" Style="{StaticResource CompactTextBox}" />

                        <TextBlock Grid.Row="5" Text="{DynamicResource LOCGT_SettingsCalibrationDuration}" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Settings.CenterCalibrationMilliseconds}" Style="{StaticResource CompactTextBox}" />
                    </Grid>

                    <TextBlock Text="{DynamicResource LOCGT_SettingsThresholdsHelp}"
                               Style="{StaticResource MutedText}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
