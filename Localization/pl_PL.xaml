    <sys:String x:Key="LOCGT_InputEventLatency">Wejście czasu zdarzenia</sys:String>
    <sys:String x:Key="LOCGT_InputEventLatencyHelp">Naciskaj przyciski wielokrotnie. Wtyczka rejestruje zaobserwowane zmiany, dzięki czemu można porównać tryby przewodowe, bezprzewodowe i Bluetooth.</sys:String>
