    <sys:String x:Key="LOCGT_PerformanceReference">Odniesienie do wydajności</sys:String>
    <sys:String x:Key="LOCGT_LatencyHelp">Oszacowuje to odstęp między próbkami obserwowanymi przez wtyczkę. Nie jest to opóźnienie sprzętowe USB, ale pomaga wykryć wolne łącza Bluetooth, drgania lub brakujące odpytywanie.</sys:String>
    <sys:String x:Key="LOCGT_LatencySimpleHelp">Kliknij przycisk, a następnie naciśnij dowolny przycisk kontrolera. Wynik pokazuje zaobserwowany czas, zanim wtyczka otrzyma dane wejściowe.</sys:String>
    <sys:String x:Key="LOCGT_StartLatency">Rozpocznij opóźnienie</sys:String>
    <sys:String x:Key="LOCGT_StopLatency">Zatrzymaj opóźnienia</sys:String>
    <sys:String x:Key="LOCGT_LatencyStoppedNoSample">Test opóźnienia został zatrzymany. Nie zarejestrowano żadnego naciśnięcia przycisku.</sys:String>
    <sys:String x:Key="LOCGT_LatencyStoppedFormat">Test opóźnienia został zatrzymany. Ostatnia przechwycona wartość: {0:0} ms.</sys:String>
    <sys:String x:Key="LOCGT_WaitingForPress">Czekanie...</sys:String>
    <sys:String x:Key="LOCGT_PressAnyGamepadButton">Naciśnij dowolny przycisk gamepada</sys:String>
    <sys:String x:Key="LOCGT_LatencyReadyHelp">Kliknij przycisk Start, a następnie naciśnij przycisk na kontrolerze.</sys:String>
