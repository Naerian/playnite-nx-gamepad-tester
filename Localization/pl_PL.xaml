    <sys:String x:Key="LOCGT_CalibrationRunningFormat">Trzymaj pałeczki puszczone. Centrum przechwytywania dla {0:0.0}.</sys:String>
    <sys:String x:Key="LOCGT_CalibrationNotRun">Kalibracja środkowa nie została jeszcze przechwycona.</sys:String>
    <sys:String x:Key="LOCGT_CalibrationSamplesFormat">Środek uchwycony na podstawie próbek {0}.</sys:String>
    <sys:String x:Key="LOCGT_CenterFormat">Środek X {0:0.000} Y {1:0.000}</sys:String>
    <sys:String x:Key="LOCGT_RecommendedDeadzoneFormat">Zalecana martwa strefa: {0}%</sys:String>
    <sys:String x:Key="LOCGT_RangeNotMeasured">Zasięg jeszcze nie zmierzony.</sys:String>
    <sys:String x:Key="LOCGT_RangeQualityFormat">Jakość poza zakresem: {0}%</sys:String>
    <sys:String x:Key="LOCGT_LatencyTitle">Opóźnienie odpytywania</sys:String>
    <sys:String x:Key="LOCGT_PollingLatencyTitle">Opóźnienie odpytywania</sys:String>
    <sys:String x:Key="LOCGT_DeviceConnected">Podłączone urządzenie</sys:String>
