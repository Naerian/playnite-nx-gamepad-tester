    <sys:String x:Key="LOCGT_SettingsPlayniteIntegration">Integracja Playnite</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSidebar">Pokaż Gamepad Tester na pasku bocznym Playnite</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSidebarHelp">Dodaje wpis Gamepad Tester do paska bocznego trybu pulpitu. Po zmianie tej opcji uruchom ponownie Playnite, aby można było odbudować pasek boczny.</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowTopPanel">Pokaż Gamepad Tester na górnym panelu Playnite</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowTopPanelHelp">Dodaje kompaktowy skrót Gamepad Tester do górnego panelu Playnite, który jest przydatny w przypadku motywów przyjaznych dla trybu pełnoekranowego.</sys:String>
    <sys:String x:Key="LOCGT_SettingsFullscreenWindow">Użyj okna przyjaznego dla pełnego ekranu w trybie pełnoekranowym</sys:String>
    <sys:String x:Key="LOCGT_SettingsFullscreenWindowHelp">Gdy Playnite jest w trybie pełnoekranowym, otwiera Gamepad Tester w wersji zmaksymalizowanej i pozostawia dostępny przycisk zamykania.</sys:String>
    <sys:String x:Key="LOCGT_SettingsTestingBehavior">Testowanie zachowania</sys:String>
    <sys:String x:Key="LOCGT_SettingsResetOnSwitch">Zresetuj diagnostykę przy przełączaniu sterownika</sys:String>
    <sys:String x:Key="LOCGT_SettingsResetOnSwitchHelp">Usuwa szybkie kontrole, przyklejane ścieżki, zasięg cykliczny i dane sesji dryfowania po wybraniu innego podłączonego urządzenia.</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSingleSelector">Pokaż selektor urządzeń nawet z jednym kontrolerem</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSingleSelectorHelp">Przydatne podczas testowania wykrywania urządzeń lub zachowania ponownego łączenia kontrolera.</sys:String>
    <sys:String x:Key="LOCGT_SettingsEnableRumble">Włącz testy dudnienia</sys:String>
    <sys:String x:Key="LOCGT_SettingsEnableRumbleHelp">Testy Rumble zależą od trybu kontrolera, obsługi sterowników i obsługi SDL dla urządzenia.</sys:String>
    <sys:String x:Key="LOCGT_SettingsInputLogDefault">Domyślnie włącz dziennik wejściowy</sys:String>
    <sys:String x:Key="LOCGT_SettingsInputLogDefaultHelp">Zachowuje zapis dziennika wejściowego po otwarciu testera. Pozostaw wyłączone dla najlżejszej sesji domyślnej.</sys:String>
    <sys:String x:Key="LOCGT_SettingsThresholds">Progi i kalibracja</sys:String>
