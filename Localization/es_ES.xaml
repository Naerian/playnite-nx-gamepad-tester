    <sys:String x:Key="LOCGT_Checklist">Lista de comprobacion</sys:String>
    <sys:String x:Key="LOCGT_ChecklistHelp">Los controles completados se resaltan. Usa Reiniciar sesion para empezar una pasada limpia.</sys:String>
    <sys:String x:Key="LOCGT_FaceButtons">Botones frontales</sys:String>
    <sys:String x:Key="LOCGT_ShouldersAndTriggers">Bumpers y gatillos</sys:String>
