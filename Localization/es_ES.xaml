    <sys:String x:Key="LOCGT_Alternating">Alterna</sys:String>
    <sys:String x:Key="LOCGT_Ramp">Rampa</sys:String>
    <sys:String x:Key="LOCGT_SettingsPlayniteIntegration">Integracion con Playnite</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSidebar">Mostrar Gamepad Tester en la barra lateral de Playnite</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSidebarHelp">Anade una entrada de Gamepad Tester a la barra lateral del modo escritorio. Reinicia Playnite tras cambiar esta opcion para reconstruir la barra lateral.</sys:String>
    <sys:String x:Key="LOCGT_SettingsTestingBehavior">Comportamiento de las pruebas</sys:String>
    <sys:String x:Key="LOCGT_SettingsResetOnSwitch">Reiniciar diagnostico al cambiar de mando</sys:String>
    <sys:String x:Key="LOCGT_SettingsResetOnSwitchHelp">Limpia comprobaciones, recorridos de sticks, cobertura circular y datos de drift de sesion al seleccionar otro dispositivo conectado.</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSingleSelector">Mostrar selector aunque solo haya un mando</sys:String>
    <sys:String x:Key="LOCGT_SettingsShowSingleSelectorHelp">Util para probar la deteccion de dispositivos o el comportamiento al reconectar mandos.</sys:String>
    <sys:String x:Key="LOCGT_SettingsEnableRumble">Activar pruebas de vibracion</sys:String>
    <sys:String x:Key="LOCGT_SettingsEnableRumbleHelp">Las pruebas de vibracion dependen del modo del mando, del soporte del driver y del soporte SDL del dispositivo.</sys:String>
    <sys:String x:Key="LOCGT_Ready">Listo</sys:String>
    <sys:String x:Key="LOCGT_ConnectControllerToStart">Conecta un mando para empezar.</sys:String>
